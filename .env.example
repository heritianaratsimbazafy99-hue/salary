NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback for older Supabase projects. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. Never expose these through NEXT_PUBLIC_ variables.
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL="MadajobPay <no-reply@your-verified-domain.tld>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry monitoring. Keep auth tokens server/build-only.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=stark-3t
SENTRY_PROJECT=salary
SENTRY_AUTH_TOKEN=
