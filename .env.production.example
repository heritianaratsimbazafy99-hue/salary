# Production environment template. Keep real values in Vercel/Supabase secrets, never in Git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=

# Sentry monitoring.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=stark-3t
SENTRY_PROJECT=salary

# Server/build-only. Never expose these through NEXT_PUBLIC_ variables.
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_AUTH_TOKEN=

# Resend application email delivery. Use a verified Resend sender domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL="MadajobPay <no-reply@your-verified-domain.tld>"
