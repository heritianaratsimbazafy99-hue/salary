{
  "name": "salary-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:secrets": "node scripts/check-secrets.mjs",
    "verify:prod-env": "node scripts/verify-prod-env.mjs",
    "db:reset:local": "supabase db reset --local",
    "db:advisors": "supabase db advisors --local --type all --level warn --fail-on error",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:ci": "npm run check:secrets && npm run verify && npm audit --audit-level=high",
    "verify:full": "npm run check:secrets && npm run verify && npm run test:e2e && npm run db:advisors && npm audit --audit-level=high"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.14.0",
    "tailwind-merge": "3.6.0",
    "exceljs": "4.4.0",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
